# Server Configuration
PORT=3210

# SignalK Configuration
SIGNALK_URL=http://localhost:3100

# Data Sources
LOGGER_DATA_DIR=/home/geoff/becoming/apps/vessel-data-logger/logs

# Storage Configuration
# MongoDB Atlas connection (preferred)
# Get your connection string from mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/becoming?retryWrites=true&w=majority
