# SignalK Connection
SIGNALK_HOST=becoming-hub
SIGNALK_PORT=3100
SIGNALK_PROTOCOL=ws

# MongoDB Atlas - Get your connection string from mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/becoming?retryWrites=true&w=majority
MONGO_URI=

# Web Server
WEB_PORT=3200

# Logging
LOG_LEVEL=info

# Cache Settings
CACHE_MAX_ENTRIES=10000
CACHE_TTL_SECONDS=300

# Telegram Notifications (optional)
# Get bot token from @BotFather on Telegram
# Get chat ID by messaging your bot and visiting:
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
